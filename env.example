# Add the needed API keys
# At minimum, you need one AI provider configured

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY="your-google-api-key-here"

# OpenAI
OPENAI_API_KEY="your-openai-api-key-here"

# OpenRouter
OPENROUTER_API_KEY="your-openrouter-api-key-here"

# AWS Bedrock - Choose ONE of the following authentication methods:

# Option 1: AWS SSO (Recommended for development)
# Run 'aws sso login' before starting the app
# Set AWS_PROFILE to your SSO profile name from ~/.aws/config
AWS_PROFILE=default
AWS_REGION=us-west-2

# Option 2: IAM Access Keys (For production or non-SSO environments)
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=your-region
